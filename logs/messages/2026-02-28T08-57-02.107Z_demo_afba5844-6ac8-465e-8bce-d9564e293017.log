t page.locator('#prompt').fill('@opus 会话A的内容');\n  await page.locator('#runBtn').click();\n  await expect(page.locator('#log')).toContainText('会话A', { timeout: 60000 });\n  \n  // 创建会话 B\n  await page.locator('#newSessionBtn').click();\n  await page.locator('#prompt').fill('@opus 会话B的内容');\n  await page.locator('#runBtn').click();\n  await expect(page.locator('#log')).toContainText('会话B', { timeout: 60000 });\n  \n  // 切换回会话 A，验证显示 A 的内容\n  await page.locator('.session-item').last().click();\n  await expect(page.locator('#log')).toContainText('会话A');\n  await expect(page.locator('#log')).not.toContainText('会话B');\n});\n```\n\n你想深入讨论哪个方面？比如：\n1. **补充具体测试用例** — 我可以帮你写完整的测试代码\n2. **测试策略讨论** — 单元测试 vs E2E 测试的覆盖边界\n3. **CI/CD 集成** — 如何在 GitHub Actions 中运行这些测试\n4. **其他功能的测试设计** — 比如之前错题本提到的 A2A 质量测试"}},"meta":{"requestId":"47ce07dd-709e-4471-965e-f01cffa13a10","runId":"afba5844-6ac8-465e-8bce-d9564e293017","pid":37154,"cwd":"/Users/qiliangli/Documents/Coding/ateam","node":"v24.13.0","platform":"darwin","hostname":"liqiliangdeMacBook-Air-2.local"}}
